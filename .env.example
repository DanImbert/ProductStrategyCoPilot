# Application
APP_NAME=Product Strategy Copilot
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
ENABLE_FILE_LOGGING=true

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=*

# LLM provider
# Default is zero-cost and fully offline-friendly for demos, tests, and benchmark baselines.
LLM_PROVIDER=mock

# OpenAI
# Optional only. You do not need a paid API to run this project.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Local OpenAI-compatible model
# Free option if you have Ollama, LM Studio, or another OpenAI-compatible local server.
# LLM_PROVIDER=local
LOCAL_API_BASE=http://localhost:11434/v1
LOCAL_MODEL=llama3.1:8b-instruct

# Runtime behavior
REQUEST_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=3

# Approximate token pricing for cost estimation
INPUT_TOKEN_COST_USD_PER_MILLION=0.40
OUTPUT_TOKEN_COST_USD_PER_MILLION=1.60
